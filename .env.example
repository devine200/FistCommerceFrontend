# WalletConnect / Reown — required for Zerion and Ledger (and any WalletConnect flow).
# Create a project at https://dashboard.reown.com and paste the ID below.
VITE_WALLETCONNECT_PROJECT_ID=

# Backend **API root** (no trailing slash). Must include the `/api` prefix used by Django.
# API reference: http://127.0.0.1:8000/redoc/ — OpenAPI JSON: http://127.0.0.1:8000/swagger.json
# Auth: POST …/auth/login (signedMessage, signature, signerAddress, role) and POST …/auth/refresh-token (refresh_token).
# Investor KYC: GET …/kyc/investor — `kyc_verification` and `insurance_verification` (or `insurance_verfication`) must both be done for verified access.
# Example (local): http://127.0.0.1:8000/api
VITE_API_BASE_URL=

# Privy (Social login + embedded wallet)
# Public App ID from the Privy dashboard.
VITE_PRIVY_APP_ID=

# Google OAuth (optional local reference). Public Web Client ID from Google Cloud Console.
# Configure the same Client ID + Client secret in Privy Dashboard → Login methods → Google (custom credentials).
# Do not put the Google client secret in any VITE_* variable (it would ship in the browser bundle).
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Ethereum Sepolia — block explorer origin (no trailing slash). Used for contract / wallet links when the API
# does not send `block_explorer_base_url`. Example: https://sepolia.etherscan.io
VITE_ETH_SEPOLIA_BLOCK_EXPLORER_URL=http://sepolia.etherscan.io/

# Optional: pool smart contract on Sepolia when `GET /api/payout/recent-transactions/` does not include it on the JSON envelope.
VITE_ETH_SEPOLIA_POOL_CONTRACT_ADDRESS=

# EIP-712 domain for POST /api/auth/login — must match the server verifier (see backend settings).
# VITE_AUTH_EIP712_DOMAIN_NAME=FistCommerce Authentication
# VITE_AUTH_EIP712_DOMAIN_VERSION=1
# VITE_AUTH_EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000
