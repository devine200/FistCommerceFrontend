# WalletConnect / Reown — required for Zerion and Ledger (and any WalletConnect flow).
# Create a project at https://dashboard.reown.com and paste the ID below.
VITE_WALLETCONNECT_PROJECT_ID=

# Backend base URL (no trailing slash). Use the server origin (`http://127.0.0.1:8000`) or API root (`…/api`).
# API reference: http://127.0.0.1:8000/redoc/ — OpenAPI JSON: http://127.0.0.1:8000/swagger.json
# Auth: POST …/auth/login (signedMessage, signature, signerAddress, role), POST …/auth/admin-login (signedMessage, signature, signerAddress — multisig owner), and POST …/auth/refresh-token (refresh_token).
# Admin dashboard: GET …/metrics/admin/, GET …/metrics/admin/requests/ (payout & withdrawal queue), POST …/metrics/admin/requests/withdrawals/{requestKey}/approve/ (may return 202 + proposalId), POST …/metrics/admin/requests/disbursements/{requestKey}/approve/ (200 + tx_hash), GET …/metrics/admin/ops/servicer-wallet/, GET/POST …/api/multisig/* (governance queue — see docs/admin-governance.md), GET …/kyc/admin/*, POST …/kyc/admin/kyc-review (may return 202), GET …/loan/admin/receivables/, GET …/loan/admin/loans/monitoring/, POST …/loan/admin/loans/{loanId}/write-off-shortfall/, GET …/config/admin/contact-social-links/, GET …/config/contact/ (public).
# Public config: GET …/config/contact/ (contact & social links for user-facing pages).
# Investor KYC: GET …/kyc/investor — Didit KYC+AML via `verification_url` after document upload; verified access when on-chain status is verified.
# Merchant KYC: GET …/kyc/merchant — Didit KYB Lite; admin must verify insurance via POST …/kyc/admin/kyc-verify before on-chain approval completes.
# Example (local): http://127.0.0.1:8000
VITE_API_BASE_URL=

# Privy (Social login + embedded wallet)
# Public App ID from the Privy dashboard.
VITE_PRIVY_APP_ID=

# Google OAuth (optional local reference). Public Web Client ID from Google Cloud Console.
# Configure the same Client ID + Client secret in Privy Dashboard → Login methods → Google (custom credentials).
# Do not put the Google client secret in any VITE_* variable (it would ship in the browser bundle).
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Arbitrum Sepolia — block explorer origin (no trailing slash). Used for contract / wallet links when the API
# does not send `block_explorer_base_url`. Example: https://sepolia.arbiscan.io
VITE_ARBITRUM_SEPOLIA_BLOCK_EXPLORER_URL=https://sepolia.arbiscan.io

# Optional: pool smart contract on Arbitrum Sepolia when `GET /api/payout/recent-transactions/` does not include it on the JSON envelope.
# Current testnet FundingPool (also in testnet-deployment-config.json):
# VITE_ARBITRUM_SEPOLIA_POOL_CONTRACT_ADDRESS=0x23bA51D34Ba508aB0DCF01C3626e4DC200dCAA3E
# Optional fallback when testnet-deployment-config.json omits MockERC20 (must match FundingPool.acceptedToken()):
# VITE_MOCK_ERC20_ADDRESS=0x9731CcecD53Bf2225bC5848e58d6338De43b4A40
VITE_ARBITRUM_SEPOLIA_POOL_CONTRACT_ADDRESS=

# Smart contract network: `testnet` (default) or `local`.
# - testnet — Arbitrum Sepolia + src/contract_config/testnet-deployment-config.json
# - local   — Anvil/Hardhat node + src/contract_config/local-deployment-config.json (update addresses after deploy)
VITE_CONTRACT_NETWORK=testnet

# Local mode only — optional overrides (defaults come from local-deployment-config.json).
# VITE_LOCAL_RPC_URL=http://127.0.0.1:8545
# VITE_LOCAL_CHAIN_ID=31337
# VITE_LOCAL_BLOCK_EXPLORER_URL=

# EIP-712 domain for POST /api/auth/login — must match the server verifier (chainId 421614 on Arbitrum Sepolia, or your local chain id).
# VITE_AUTH_EIP712_DOMAIN_NAME=FistCommerce Authentication
# VITE_AUTH_EIP712_DOMAIN_VERSION=1
# VITE_AUTH_EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000000

# Pinata dedicated gateway — must match backend PINATA_GATEWAY_SUBDOMAIN when resolving CIDs client-side.
# VITE_PINATA_GATEWAY_SUBDOMAIN=aquamarine-rabbit-123
# VITE_PINATA_GATEWAY_BASE_URL=https://aquamarine-rabbit-123.mypinata.cloud/ipfs

# Beta session diagnostics (console + sessionStorage). On by default; set to 0/false to disable.
# Console: __fcSessionDiag.dump() | __fcSessionDiag.resetLocalSession() | ?fc_reset_session=1
# VITE_SESSION_DIAGNOSTICS=1
